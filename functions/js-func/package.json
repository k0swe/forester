  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "10.6.0",
    "eslint-config-google": "0.14.0",
    "firebase-functions-test": "3.5.0",
    "typescript": "5.9.3"
